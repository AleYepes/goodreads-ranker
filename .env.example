# Copy this file to .env and fill in your values.
# You can also run `python main.py init` to be guided through setup interactively.

# Your Goodreads account credentials (required for seeding library shelves).
GOODREADS_EMAIL=your.email@example.com
GOODREADS_PASSWORD=your_password_here

# The Ollama model used to generate book embeddings.
# Run `ollama list` to see locally available models.
# Default if unset: qwen3-embedding:8b
OLLAMA_EMBEDDING_MODEL=your_desired_model